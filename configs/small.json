{
  "model": {
    "vocab_size": 32000,
    "max_seq_len": 1024,
    "dim": 768,
    "n_layers": 12,
    "n_heads": 12,
    "n_kv_heads": 4,
    "intermediate_size": 2048,
    "norm_eps": 1e-05,
    "rope_theta": 10000.0,
    "dropout": 0.0,
    "tie_embeddings": true,
    "initializer_range": 0.02
  },
  "train": {
    "seq_len": 1024,
    "micro_batch_size": 4,
    "grad_accum_steps": 2,
    "max_steps": 5000,
    "lr": 6e-04,
    "min_lr": 6e-05,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0,
    "warmup_steps": 100,
    "lr_decay_steps": 5000,
    "dtype": "bfloat16",
    "activation_checkpointing": false,
    "compile": false,
    "fsdp_sharding": "full",
    "cpu_offload": false,
    "out_dir": "runs/small",
    "save_every": 1000,
    "eval_every": 500,
    "eval_iters": 50,
    "log_every": 10,
    "seed": 1337
  }
}
