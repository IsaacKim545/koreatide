{
  "model": {
    "vocab_size": 2000,
    "max_seq_len": 256,
    "dim": 128,
    "n_layers": 4,
    "n_heads": 4,
    "n_kv_heads": 2,
    "intermediate_size": 256,
    "norm_eps": 1e-05,
    "rope_theta": 10000.0,
    "dropout": 0.0,
    "tie_embeddings": true,
    "initializer_range": 0.02
  },
  "train": {
    "seq_len": 64,
    "micro_batch_size": 4,
    "grad_accum_steps": 1,
    "max_steps": 200,
    "lr": 3e-04,
    "min_lr": 3e-05,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0,
    "warmup_steps": 20,
    "lr_decay_steps": 200,
    "dtype": "float32",
    "activation_checkpointing": false,
    "compile": false,
    "fsdp_sharding": "none",
    "cpu_offload": false,
    "out_dir": "runs/demo",
    "save_every": 200,
    "eval_every": 100000,
    "eval_iters": 10,
    "log_every": 20,
    "seed": 1337
  }
}
